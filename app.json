{
  "expo": {
    "name": "Taurus",
    "slug": "taurus-mobile",
    "scheme": ["taurus-mobile", "gymtaurus"],
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.devharsue.taurusmobile"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Permitir a Taurus usar la cámara para escanear el QR de los miembros."
        }
      ],
      "expo-web-browser",
      "expo-font",
      "expo-sharing",
      "expo-audio"
    ],
    "extra": {
      "eas": {
        "projectId": "4617fc1c-7d68-4eb1-b5f1-e3ffe049a924"
      }
    }
  }
}
